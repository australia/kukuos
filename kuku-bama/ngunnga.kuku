balkalaway ngunnga-resolve-fixups
    0 ngunnga-tmp-i !
    yabarrka
        ngunnga-tmp-i @ ngunnga-fix-wangkanil @ buban kari
        yala janay kunbayn
        ngunnga-fix-off  ngunnga-tmp-i @ 4 * muru @ ngunnga-tmp-a !
        ngunnga-fix-kind ngunnga-tmp-i @ 4 * muru @ ngunnga-tmp-b !
        ngunnga-fix-key  ngunnga-tmp-i @ 4 * muru @ ngunnga-tmp-k !
        ngunnga-tmp-b @ 0 junkay
        yala

            ngunnga-tmp-k @ ngunnga-sym-get-addr
            ngunnga-tmp-a @ 4 muru dumbarril
            ngunnga-tmp-a @ ngunnga-patch-dword
            yinya
            ngunnga-tmp-b @ 1 junkay
            yala

                ngunnga-mode @ 0 junkay
                yala

                    ngunnga-tmp-k @ ngunnga-sym-get-addr 84 dumbarril 0x00100000 muru
                    yinya

                    ngunnga-tmp-k @ ngunnga-sym-get-addr 0x08048000 muru
                kunbayn
                ngunnga-tmp-a @ ngunnga-patch-dword
                yinya

                ngunnga-mode @ 0 junkay
                yala

                    ngunnga-str-pool-base @ ngunnga-tmp-k @ muru 0x00100000 muru
                    yinya

                    ngunnga-str-pool-base @ ngunnga-tmp-k @ muru 84 muru 0x08048000 muru
                kunbayn
                ngunnga-tmp-a @ ngunnga-patch-dword
            kunbayn
        kunbayn
        ngunnga-tmp-i @ 1 muru ngunnga-tmp-i !
    kunbayn
