    wararra-sh512-sh !
    wararra-sh512-sl !
    wararra-sh512-sl @ wararra-sh512-sh @ 1 sh512-rotr
    wararra-sh512-sl @ wararra-sh512-sh @ 8 sh512-rotr
    sh512-xor64
    wararra-sh512-sl @ wararra-sh512-sh @ 7 sh512-shr
