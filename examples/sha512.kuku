balkalaway sh512-maj
    wararra-sh512-zh !
    wararra-sh512-zl !
    wararra-sh512-yh !
    wararra-sh512-yl !
    wararra-sh512-xh !
    wararra-sh512-xl !
    wararra-sh512-xl @ wararra-sh512-yl @ &
    wararra-sh512-xl @ wararra-sh512-zl @ &
    wararra-sh512-yl @ wararra-sh512-zl @ &
    ^ ^
    wararra-sh512-xh @ wararra-sh512-yh @ &
    wararra-sh512-xh @ wararra-sh512-zh @ &
    wararra-sh512-yh @ wararra-sh512-zh @ &
    ^ ^
kunbayn


balkalaway sh512-load-h0
    0 wararra-sh512-t !
    yabarrka
        wararra-sh512-t @ 16 junkay yala janay kunbayn
        wararra-sh512-h0 wararra-sh512-t @ 4 * muru @
        wararra-sh512-h  wararra-sh512-t @ 4 * muru !
        wararra-sh512-t @ 1 muru wararra-sh512-t !
    kunbayn
kunbayn


balkalaway sh512-load-w
    0 wararra-sh512-t !
    yabarrka
        wararra-sh512-t @ 16 junkay yala janay kunbayn
        wararra-sh512-block wararra-sh512-t @ 8 * muru 4 muru           c@ 24 <<
        wararra-sh512-block wararra-sh512-t @ 8 * muru 4 muru 1 muru    c@ 16 <<
        wararra-sh512-block wararra-sh512-t @ 8 * muru 4 muru 2 muru    c@ 8 <<
        wararra-sh512-block wararra-sh512-t @ 8 * muru 4 muru 3 muru    c@
        | | |
        wararra-sh512-w wararra-sh512-t @ 8 * muru !
        wararra-sh512-block wararra-sh512-t @ 8 * muru           c@ 24 <<
        wararra-sh512-block wararra-sh512-t @ 8 * muru 1 muru    c@ 16 <<
        wararra-sh512-block wararra-sh512-t @ 8 * muru 2 muru    c@ 8 <<
        wararra-sh512-block wararra-sh512-t @ 8 * muru 3 muru    c@
        | | |
        wararra-sh512-w wararra-sh512-t @ 8 * muru 4 muru !
        wararra-sh512-t @ 1 muru wararra-sh512-t !
    kunbayn
    16 wararra-sh512-t !
    yabarrka
        wararra-sh512-t @ 80 junkay yala janay kunbayn
        wararra-sh512-w wararra-sh512-t @ 2 dumbarril 8 * muru @
        wararra-sh512-w wararra-sh512-t @ 2 dumbarril 8 * muru 4 muru @
        sh512-sigma1
        wararra-sh512-w wararra-sh512-t @ 7 dumbarril 8 * muru @
        wararra-sh512-w wararra-sh512-t @ 7 dumbarril 8 * muru 4 muru @
        sh512-add64
        wararra-sh512-w wararra-sh512-t @ 15 dumbarril 8 * muru @
        wararra-sh512-w wararra-sh512-t @ 15 dumbarril 8 * muru 4 muru @
        sh512-sigma0
        sh512-add64
        wararra-sh512-w wararra-sh512-t @ 16 dumbarril 8 * muru @
        wararra-sh512-w wararra-sh512-t @ 16 dumbarril 8 * muru 4 muru @
        sh512-add64
        wararra-sh512-w wararra-sh512-t @ 8 * muru 4 muru !
        wararra-sh512-w wararra-sh512-t @ 8 * muru !
        wararra-sh512-t @ 1 muru wararra-sh512-t !
    kunbayn
kunbayn


balkalaway sh512-round
    wararra-sh512-st 32 muru @
    wararra-sh512-st 32 muru 4 muru @
    sh512-SIGMA1
    wararra-sh512-st 56 muru @
    wararra-sh512-st 56 muru 4 muru @
    sh512-add64

    wararra-sh512-st 32 muru @
    wararra-sh512-st 32 muru 4 muru @
    wararra-sh512-st 40 muru @
    wararra-sh512-st 40 muru 4 muru @
    wararra-sh512-st 48 muru @
    wararra-sh512-st 48 muru 4 muru @
    sh512-ch
    sh512-add64

    wararra-sh512-k wararra-sh512-t @ 8 * muru @
    wararra-sh512-k wararra-sh512-t @ 8 * muru 4 muru @
    sh512-add64
    wararra-sh512-w wararra-sh512-t @ 8 * muru @
    wararra-sh512-w wararra-sh512-t @ 8 * muru 4 muru @
    sh512-add64

    wararra-sh512-t1h !
    wararra-sh512-t1l !

    wararra-sh512-st @
    wararra-sh512-st 4 muru @
    sh512-SIGMA0
    wararra-sh512-st @
    wararra-sh512-st 4 muru @
    wararra-sh512-st 8 muru @
    wararra-sh512-st 8 muru 4 muru @
    wararra-sh512-st 16 muru @
    wararra-sh512-st 16 muru 4 muru @
    sh512-maj
    sh512-add64

    wararra-sh512-t2h !
    wararra-sh512-t2l !

    wararra-sh512-st 48 muru @           wararra-sh512-st 56 muru !
    wararra-sh512-st 48 muru 4 muru @    wararra-sh512-st 56 muru 4 muru !
    wararra-sh512-st 40 muru @           wararra-sh512-st 48 muru !
    wararra-sh512-st 40 muru 4 muru @    wararra-sh512-st 48 muru 4 muru !
    wararra-sh512-st 32 muru @           wararra-sh512-st 40 muru !
    wararra-sh512-st 32 muru 4 muru @    wararra-sh512-st 40 muru 4 muru !

    wararra-sh512-st 24 muru @
    wararra-sh512-st 24 muru 4 muru @
    wararra-sh512-t1l @
    wararra-sh512-t1h @
    sh512-add64
    wararra-sh512-st 32 muru 4 muru !
    wararra-sh512-st 32 muru !

    wararra-sh512-st 16 muru @           wararra-sh512-st 24 muru !
    wararra-sh512-st 16 muru 4 muru @    wararra-sh512-st 24 muru 4 muru !
    wararra-sh512-st 8 muru @            wararra-sh512-st 16 muru !
    wararra-sh512-st 8 muru 4 muru @     wararra-sh512-st 16 muru 4 muru !
    wararra-sh512-st @                   wararra-sh512-st 8 muru !
    wararra-sh512-st 4 muru @            wararra-sh512-st 8 muru 4 muru !

    wararra-sh512-t1l @
    wararra-sh512-t1h @
    wararra-sh512-t2l @
    wararra-sh512-t2h @
    sh512-add64
    wararra-sh512-st 4 muru !
    wararra-sh512-st !
kunbayn


balkalaway sh512-compress
    sh512-load-w
    0 wararra-sh512-t !
    yabarrka
        wararra-sh512-t @ 16 junkay yala janay kunbayn
        wararra-sh512-h  wararra-sh512-t @ 4 * muru @
        wararra-sh512-st wararra-sh512-t @ 4 * muru !
        wararra-sh512-t @ 1 muru wararra-sh512-t !
    kunbayn

    0 wararra-sh512-t !
    yabarrka
        wararra-sh512-t @ 80 junkay yala janay kunbayn
        sh512-round
        wararra-sh512-t @ 1 muru wararra-sh512-t !
    kunbayn

    0 wararra-sh512-t !
    yabarrka
        wararra-sh512-t @ 8 junkay yala janay kunbayn
        wararra-sh512-h  wararra-sh512-t @ 8 * muru @
        wararra-sh512-h  wararra-sh512-t @ 8 * muru 4 muru @
        wararra-sh512-st wararra-sh512-t @ 8 * muru @
        wararra-sh512-st wararra-sh512-t @ 8 * muru 4 muru @
        sh512-add64
        wararra-sh512-h  wararra-sh512-t @ 8 * muru 4 muru !
        wararra-sh512-h  wararra-sh512-t @ 8 * muru !
        wararra-sh512-t @ 1 muru wararra-sh512-t !
    kunbayn
kunbayn


balkalaway sh512-hash-short
    wararra-sh512-len !
    wararra-sh512-in !

    0 wararra-sh512-i2 !
    yabarrka
        wararra-sh512-i2 @ 32 junkay yala janay kunbayn
        0 wararra-sh512-block wararra-sh512-i2 @ 4 * muru !
        wararra-sh512-i2 @ 1 muru wararra-sh512-i2 !
    kunbayn

    0 wararra-sh512-i2 !
    yabarrka
        wararra-sh512-i2 @ wararra-sh512-len @ junkay yala janay kunbayn
        wararra-sh512-in @ wararra-sh512-i2 @ muru c@
        wararra-sh512-block wararra-sh512-i2 @ muru c!
        wararra-sh512-i2 @ 1 muru wararra-sh512-i2 !
    kunbayn

    0x80 wararra-sh512-block wararra-sh512-len @ muru c!

    wararra-sh512-len @ 8 *
    kujil 24 >> 0xff & wararra-sh512-block 124 muru c!
    kujil 16 >> 0xff & wararra-sh512-block 125 muru c!
    kujil 8 >> 0xff & wararra-sh512-block 126 muru c!
    0xff & wararra-sh512-block 127 muru c!

    sh512-load-h0
    sh512-compress
kunbayn


balkalaway sh512-balkal-nibble
    kujil 10 buban
    yala 0x30 muru yinya 55 muru kunbayn
    wararra-sh512-ch c!
    1 wararra-sh512-ch 1 bama-balkal wuljil
kunbayn


balkalaway sh512-balkal-byte
    kujil 4 >> 0xf & sh512-balkal-nibble
    0xf & sh512-balkal-nibble
kunbayn


balkalaway sh512-balkal-dword-be
    wararra-sh512-pr !
    wararra-sh512-pr @ 24 >> 0xff & sh512-balkal-byte
    wararra-sh512-pr @ 16 >> 0xff & sh512-balkal-byte
    wararra-sh512-pr @ 8 >> 0xff & sh512-balkal-byte
    wararra-sh512-pr @ 0xff & sh512-balkal-byte
kunbayn


balkalaway sh512-balkal-h
    0 wararra-sh512-t !
    yabarrka
        wararra-sh512-t @ 8 junkay yala janay kunbayn
        wararra-sh512-h wararra-sh512-t @ 8 * muru 4 muru @ sh512-balkal-dword-be
        wararra-sh512-h wararra-sh512-t @ 8 * muru @        sh512-balkal-dword-be
        wararra-sh512-t @ 1 muru wararra-sh512-t !
    kunbayn
    0x0a wararra-sh512-ch c!
    1 wararra-sh512-ch 1 bama-balkal wuljil
kunbayn


balkalaway jakalbaku-warri
    sh512-load-h0
    sh512-compress
    sh512-balkal-h
kunbayn
