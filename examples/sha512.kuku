    wararra-sh512-rh !
    wararra-sh512-rl !
    wararra-sh512-rl @ wararra-sh512-rn @ >>
    wararra-sh512-rh @ 32 wararra-sh512-rn @ dumbarril <<
    |
    wararra-sh512-rh @ wararra-sh512-rn @ >>
kunbayn


