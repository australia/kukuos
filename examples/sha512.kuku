balkalaway sh512-add64
    wararra-sh512-yh !
    wararra-sh512-yl !
    wararra-sh512-xh !
    wararra-sh512-xl !
    wararra-sh512-xl @ wararra-sh512-yl @ muru-jambul
    wararra-sh512-xh @ wararra-sh512-yh @ muru muru
kunbayn


balkalaway sh512-xor64
    wararra-sh512-yh !
    wararra-sh512-yl !
    wararra-sh512-xh !
    wararra-sh512-xl !
    wararra-sh512-xl @ wararra-sh512-yl @ ^
    wararra-sh512-xh @ wararra-sh512-yh @ ^
kunbayn


balkalaway sh512-rotr
    wararra-sh512-rn !
    wararra-sh512-rh !
    wararra-sh512-rl !
    wararra-sh512-rn @ 32 buban kari yala
        wararra-sh512-rl @ wararra-sh512-rh @
        wararra-sh512-rl !
        wararra-sh512-rh !
        wararra-sh512-rn @ 32 dumbarril wararra-sh512-rn !
    kunbayn
    wararra-sh512-rl @ wararra-sh512-rn @ >>
    wararra-sh512-rh @ 32 wararra-sh512-rn @ dumbarril <<
    |
    wararra-sh512-rh @ wararra-sh512-rn @ >>
    wararra-sh512-rl @ 32 wararra-sh512-rn @ dumbarril <<
    |
kunbayn


