balkalaway pt-add
    wararra-pt-qT !
    wararra-pt-qZ !
    wararra-pt-qY !
    wararra-pt-qX !
    wararra-pt-pT !
    wararra-pt-pZ !
    wararra-pt-pY !
    wararra-pt-pX !
    wararra-pt-rT !
    wararra-pt-rZ !
    wararra-pt-rY !
    wararra-pt-rX !

    wararra-pt-t1 wararra-pt-pY @ wararra-pt-pX @ fe-sub
    wararra-pt-t2 wararra-pt-qY @ wararra-pt-qX @ fe-sub
    wararra-pt-A  wararra-pt-t1 wararra-pt-t2 fe-mul

    wararra-pt-t1 wararra-pt-pY @ wararra-pt-pX @ fe-add
    wararra-pt-t2 wararra-pt-qY @ wararra-pt-qX @ fe-add
    wararra-pt-B  wararra-pt-t1 wararra-pt-t2 fe-mul

    wararra-pt-t1 wararra-pt-pT @ wararra-pt-qT @ fe-mul
    wararra-pt-C  wararra-pt-t1 wararra-pt-2d fe-mul

    wararra-pt-t1 wararra-pt-pZ @ wararra-pt-qZ @ fe-mul
    wararra-pt-D  wararra-pt-t1 wararra-pt-t1 fe-add

    wararra-pt-E wararra-pt-B wararra-pt-A fe-sub
    wararra-pt-F wararra-pt-D wararra-pt-C fe-sub
    wararra-pt-G wararra-pt-D wararra-pt-C fe-add
    wararra-pt-H wararra-pt-B wararra-pt-A fe-add

    wararra-pt-rX @ wararra-pt-E wararra-pt-F fe-mul
    wararra-pt-rY @ wararra-pt-G wararra-pt-H fe-mul
    wararra-pt-rZ @ wararra-pt-F wararra-pt-G fe-mul
    wararra-pt-rT @ wararra-pt-E wararra-pt-H fe-mul
kunbayn


balkalaway pt-double
    wararra-pt-pT !
    wararra-pt-pZ !
    wararra-pt-pY !
    wararra-pt-pX !
    wararra-pt-rT !
    wararra-pt-rZ !
    wararra-pt-rY !
    wararra-pt-rX !

    wararra-pt-A wararra-pt-pX @ wararra-pt-pX @ fe-mul
    wararra-pt-B wararra-pt-pY @ wararra-pt-pY @ fe-mul
    wararra-pt-t1 wararra-pt-pZ @ wararra-pt-pZ @ fe-mul
    wararra-pt-C wararra-pt-t1 wararra-pt-t1 fe-add

    wararra-pt-D wararra-pt-zero wararra-pt-A fe-sub

    wararra-pt-t1 wararra-pt-pX @ wararra-pt-pY @ fe-add
    wararra-pt-t2 wararra-pt-t1 wararra-pt-t1 fe-mul
    wararra-pt-t1 wararra-pt-t2 wararra-pt-A fe-sub
    wararra-pt-E wararra-pt-t1 wararra-pt-B fe-sub

    wararra-pt-G wararra-pt-D wararra-pt-B fe-add
    wararra-pt-F wararra-pt-G wararra-pt-C fe-sub
    wararra-pt-H wararra-pt-D wararra-pt-B fe-sub

    wararra-pt-rX @ wararra-pt-E wararra-pt-F fe-mul
    wararra-pt-rY @ wararra-pt-G wararra-pt-H fe-mul
    wararra-pt-rZ @ wararra-pt-F wararra-pt-G fe-mul
    wararra-pt-rT @ wararra-pt-E wararra-pt-H fe-mul
kunbayn


