    pt-double

    wararra-pt-zinv wararra-pt-res-Z fe-invert
    wararra-pt-ax wararra-pt-res-X wararra-pt-zinv fe-mul
    wararra-pt-ay wararra-pt-res-Y wararra-pt-zinv fe-mul
    wararra-pt-ax fe-canon
    wararra-pt-ay fe-canon
    wararra-pt-ax fe-balkal
    wararra-pt-ay fe-balkal

    wararra-pt-res-X wararra-pt-res-Y wararra-pt-res-Z wararra-pt-res-T
    wararra-pt-base-X wararra-pt-base-Y wararra-pt-base-Z wararra-pt-base-T
    wararra-pt-base-X wararra-pt-base-Y wararra-pt-base-Z wararra-pt-base-T
    pt-add

    wararra-pt-zinv wararra-pt-res-Z fe-invert
    wararra-pt-ax wararra-pt-res-X wararra-pt-zinv fe-mul
    wararra-pt-ay wararra-pt-res-Y wararra-pt-zinv fe-mul
