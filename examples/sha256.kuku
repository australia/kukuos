balkalaway sha-rotr
    wararra-sha-rn !
    wararra-sha-rx !
    wararra-sha-rx @ wararra-sha-rn @ >>
    wararra-sha-rx @ 32 wararra-sha-rn @ dumbarril <<
    |
kunbayn


balkalaway sha-sigma-0
    wararra-sha-sy !
    wararra-sha-sy @ 7 sha-rotr
    wararra-sha-sy @ 18 sha-rotr
    wararra-sha-sy @ 3 >>
    ^ ^
kunbayn


balkalaway sha-sigma-1
    wararra-sha-sy !
    wararra-sha-sy @ 17 sha-rotr
    wararra-sha-sy @ 19 sha-rotr
    wararra-sha-sy @ 10 >>
    ^ ^
kunbayn


balkalaway sha-SIGMA-0
    wararra-sha-sy !
    wararra-sha-sy @ 2 sha-rotr
    wararra-sha-sy @ 13 sha-rotr
    wararra-sha-sy @ 22 sha-rotr
    ^ ^
kunbayn


balkalaway sha-SIGMA-1
    wararra-sha-sy !
    wararra-sha-sy @ 6 sha-rotr
    wararra-sha-sy @ 11 sha-rotr
    wararra-sha-sy @ 25 sha-rotr
    ^ ^
kunbayn


balkalaway sha-ch
    wararra-sha-cz !
    wararra-sha-cy !
    wararra-sha-cx !
    wararra-sha-cy @ wararra-sha-cz @ ^
    wararra-sha-cx @ &
    wararra-sha-cz @ ^
kunbayn


balkalaway sha-maj
    wararra-sha-mz !
    wararra-sha-my !
    wararra-sha-mx !
    wararra-sha-mx @ wararra-sha-my @ &
    wararra-sha-mx @ wararra-sha-mz @ &
    wararra-sha-my @ wararra-sha-mz @ &
    ^ ^
kunbayn


balkalaway sha-round
    wararra-sha-st 16 muru @ sha-SIGMA-1
    wararra-sha-st 28 muru @ muru
    wararra-sha-st 16 muru @
    wararra-sha-st 20 muru @
    wararra-sha-st 24 muru @
    sha-ch muru
    wararra-sha-k wararra-sha-t @ 4 * muru @ muru
    wararra-sha-w wararra-sha-t @ 4 * muru @ muru
    wararra-sha-t1 !

    wararra-sha-st @ sha-SIGMA-0
    wararra-sha-st @
    wararra-sha-st 4 muru @
    wararra-sha-st 8 muru @
    sha-maj muru
    wararra-sha-t2 !

    wararra-sha-st 24 muru @  wararra-sha-st 28 muru !
    wararra-sha-st 20 muru @  wararra-sha-st 24 muru !
    wararra-sha-st 16 muru @  wararra-sha-st 20 muru !
    wararra-sha-st 12 muru @  wararra-sha-t1 @ muru  wararra-sha-st 16 muru !
    wararra-sha-st 8 muru @   wararra-sha-st 12 muru !
    wararra-sha-st 4 muru @   wararra-sha-st 8 muru !
    wararra-sha-st @          wararra-sha-st 4 muru !
    wararra-sha-t1 @ wararra-sha-t2 @ muru  wararra-sha-st !
kunbayn


balkalaway sha-load-h0
    0 wararra-sha-t !
    yabarrka
        wararra-sha-t @ 8 junkay yala janay kunbayn
        wararra-sha-h0 wararra-sha-t @ 4 * muru @
        wararra-sha-h  wararra-sha-t @ 4 * muru !
        wararra-sha-t @ 1 muru wararra-sha-t !
    kunbayn
kunbayn


balkalaway sha-load-w
    0 wararra-sha-t !
    yabarrka
        wararra-sha-t @ 16 junkay yala janay kunbayn
        wararra-sha-block wararra-sha-t @ 4 * muru           c@ 24 <<
        wararra-sha-block wararra-sha-t @ 4 * muru 1 muru    c@ 16 <<
        wararra-sha-block wararra-sha-t @ 4 * muru 2 muru    c@ 8 <<
        wararra-sha-block wararra-sha-t @ 4 * muru 3 muru    c@
        | | |
        wararra-sha-w wararra-sha-t @ 4 * muru !
        wararra-sha-t @ 1 muru wararra-sha-t !
    kunbayn
    16 wararra-sha-t !
    yabarrka
        wararra-sha-t @ 64 junkay yala janay kunbayn
        wararra-sha-w wararra-sha-t @ 2 dumbarril 4 * muru @  sha-sigma-1
        wararra-sha-w wararra-sha-t @ 7 dumbarril 4 * muru @  muru
        wararra-sha-w wararra-sha-t @ 15 dumbarril 4 * muru @ sha-sigma-0  muru
        wararra-sha-w wararra-sha-t @ 16 dumbarril 4 * muru @ muru
        wararra-sha-w wararra-sha-t @ 4 * muru !
        wararra-sha-t @ 1 muru wararra-sha-t !
    kunbayn
kunbayn


balkalaway sha-compress
    sha-load-w
    0 wararra-sha-t !
    yabarrka
        wararra-sha-t @ 8 junkay yala janay kunbayn
        wararra-sha-h  wararra-sha-t @ 4 * muru @
        wararra-sha-st wararra-sha-t @ 4 * muru !
        wararra-sha-t @ 1 muru wararra-sha-t !
    kunbayn
    0 wararra-sha-t !
    yabarrka
        wararra-sha-t @ 64 junkay yala janay kunbayn
        sha-round
        wararra-sha-t @ 1 muru wararra-sha-t !
    kunbayn
    0 wararra-sha-t !
    yabarrka
        wararra-sha-t @ 8 junkay yala janay kunbayn
        wararra-sha-h  wararra-sha-t @ 4 * muru @
        wararra-sha-st wararra-sha-t @ 4 * muru @
        muru
        wararra-sha-h  wararra-sha-t @ 4 * muru !
        wararra-sha-t @ 1 muru wararra-sha-t !
    kunbayn
kunbayn


balkalaway sha-balkal-nibble
    kujil 10 buban
    yala 0x30 muru yinya 55 muru kunbayn
    wararra-sha-onechar c!
    1 wararra-sha-onechar 1 bama-balkal wuljil
kunbayn


balkalaway sha-balkal-byte
    kujil 4 >> 0xF & sha-balkal-nibble
    0xF & sha-balkal-nibble
kunbayn


balkalaway sha-balkal-dword-be
    wararra-sha-pr !
    wararra-sha-pr @ 24 >> 0xFF & sha-balkal-byte
    wararra-sha-pr @ 16 >> 0xFF & sha-balkal-byte
    wararra-sha-pr @ 8 >> 0xFF & sha-balkal-byte
    wararra-sha-pr @ 0xFF & sha-balkal-byte
kunbayn


balkalaway sha-balkal-h
    0 wararra-sha-t !
    yabarrka
        wararra-sha-t @ 8 junkay yala janay kunbayn
        wararra-sha-h wararra-sha-t @ 4 * muru @ sha-balkal-dword-be
        wararra-sha-t @ 1 muru wararra-sha-t !
    kunbayn
    0x0A wararra-sha-onechar c!
    1 wararra-sha-onechar 1 bama-balkal wuljil
kunbayn


balkalaway sha-balkal-newline
    0x0A wararra-sha-onechar c!
    1 wararra-sha-onechar 1 bama-balkal wuljil
kunbayn


balkalaway jakalbaku-warri
    sha-load-h0
    sha-compress
    sha-balkal-h
kunbayn
