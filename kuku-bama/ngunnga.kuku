    "bama-balkal" 0    22  0x8B 0x55 0x00 0x8B 0x4D 0x04 0x8B 0x5D 0x08 0xB8 0x04 0x00 0x00 0x00 0xCD 0x80 0x83 0xC5 0x08 0x89 0x45 0x00
    "bama-babaji" 0    22  0x8B 0x55 0x00 0x8B 0x4D 0x04 0x8B 0x5D 0x08 0xB8 0x03 0x00 0x00 0x00 0xCD 0x80 0x83 0xC5 0x08 0x89 0x45 0x00
    "bama-ngunnga" 0   24  0x8B 0x4D 0x00 0x8B 0x5D 0x04 0xBA 0xED 0x01 0x00 0x00 0xB8 0x05 0x00 0x00 0x00 0xCD 0x80 0x83 0xC5 0x04 0x89 0x45 0x00
    "bama-nandal" 0    13  0x8B 0x5D 0x00 0xB8 0x06 0x00 0x00 0x00 0xCD 0x80 0x89 0x45 0x00
    "bama-jirray" 0    13  0x8B 0x5D 0x00 0xB8 0x2D 0x00 0x00 0x00 0xCD 0x80 0x89 0x45 0x00
    "bama-dukul" 0     22  0x8B 0x55 0x00 0x8B 0x4D 0x04 0x8B 0x5D 0x08 0xB8 0xDC 0x00 0x00 0x00 0xCD 0x80 0x83 0xC5 0x08 0x89 0x45 0x00

    # integer division and modulo (signed)
    "kulbal"  0  13  0x8B 0x45 0x04  0x99  0xF7 0x7D 0x00  0x83 0xC5 0x04  0x89 0x45 0x00
    "kanbal"  0  13  0x8B 0x45 0x04  0x99  0xF7 0x7D 0x00  0x83 0xC5 0x04  0x89 0x55 0x00

    # === x87 floating-point primitives (bana-*) ===
    # All doubles live in memory as 8-byte IEEE-754 binary64.  The FPU
    # register-stack is used as a scratch during arithmetic.  Addresses are
    # passed on the data stack (as normal 32-bit ints); doubles never sit
    # directly on the data stack.

    # bana-@  (addr --)   FLD qword [addr]; pops the addr off the data stack.
    "bana-@"   0   8   0x8B 0x45 0x00  0x83 0xC5 0x04  0xDD 0x00

    # bana-!  (addr --)   FSTP qword [addr]; pops the addr, pops the FPU.
    "bana-!"   0   8   0x8B 0x45 0x00  0x83 0xC5 0x04  0xDD 0x18

    # bana-from-int  (n --)   FILD dword [ebp]; pops the int.
    "bana-from-int"   0   6   0xDB 0x45 0x00  0x83 0xC5 0x04

    # bana-to-int   (-- n)   FISTP dword into a new data-stack slot.
    "bana-to-int"     0   6   0x83 0xED 0x04  0xDB 0x5D 0x00

    # FPU-stack shuffles
    "bana-kujil"      0   2   0xD9 0xC0             # FLD ST(0)
    "bana-wuljil"     0   2   0xDD 0xD8             # FSTP ST(0)
    "bana-wundil"     0   2   0xD9 0xC9             # FXCH ST(1)

    # FPU-stack constants
    "bana-jakalbaku"  0   2   0xD9 0xEE             # FLDZ  (push 0.0)
    "bana-nyubun"     0   2   0xD9 0xE8             # FLD1  (push 1.0)

    # FPU arithmetic (ST(0) combined with ST(1), then pop)
    "bana-muru"       0   2   0xDE 0xC1             # FADDP
    "bana-dumbarril"  0   2   0xDE 0xE9             # FSUBP  (ST(1)-ST(0))
    "bana-*"          0   2   0xDE 0xC9             # FMULP
    "bana-/"          0   2   0xDE 0xF9             # FDIVP

    # Unary FPU ops (operate on ST(0), no pop)
    "bana-sqrt"       0   2   0xD9 0xFA             # FSQRT
    "bana-neg"        0   2   0xD9 0xE0             # FCHS
    "bana-sin"        0   2   0xD9 0xFE             # FSIN
    "bana-cos"        0   2   0xD9 0xFF             # FCOS

    # bana-log:  ln(ST(0))  =  ln(2) * log2(ST(0))   via FYL2X
    "bana-log"        0   6   0xD9 0xED  0xD9 0xC9  0xD9 0xF1

    # bana-exp:  e^ST(0)  =  2^(ST(0) * log2(e)).   32 bytes.
    "bana-exp"  0   32
        0xD9 0xEA  0xDE 0xC9  0xD9 0xC0  0xD9 0xE8  0xD9 0xC9  0xD9 0xF8
        0xDD 0xD9  0xD9 0xC9  0xD8 0xE1  0xD9 0xFC  0xD9 0xC9  0xD9 0xF0
        0xD9 0xE8  0xDE 0xC1  0xD9 0xFD  0xDD 0xD9

    # FPU comparisons: pop both floats, push 0|1 to data stack.
    # Semantics: `a bana-@  b bana-@  bana-junkay`  gives (a == b).
    "bana-junkay"  0  16  0xDF 0xF1  0xDD 0xD8  0x0F 0x94 0xC0  0x0F 0xB6 0xC0  0x83 0xED 0x04  0x89 0x45 0x00
    "bana-jirray"  0  16  0xDF 0xF1  0xDD 0xD8  0x0F 0x92 0xC0  0x0F 0xB6 0xC0  0x83 0xED 0x04  0x89 0x45 0x00
    "bana-buban"   0  16  0xDF 0xF1  0xDD 0xD8  0x0F 0x97 0xC0  0x0F 0xB6 0xC0  0x83 0xED 0x04  0x89 0x45 0x00
    0
nandal

balkalaway ngunnga-try-primitive

    ngunnga-tmp-k !
    ngunnga-prim-records ngunnga-tmp-a !
    yabarrka
        ngunnga-tmp-a @ c@ 0 junkay
        yala 0 janay kunbayn
        ngunnga-tmp-a @ ngunnga-tmp-k @ ngunnga-streq
        yala

            yabarrka
                ngunnga-tmp-a @ c@ 0 junkay yala janay kunbayn
                ngunnga-tmp-a @ 1 muru ngunnga-tmp-a !
            kunbayn
            ngunnga-tmp-a @ 1 muru ngunnga-tmp-a !

            ngunnga-tmp-a @ c@ ngunnga-tmp-i !
            ngunnga-tmp-a @ 1 muru ngunnga-tmp-a !

            ngunnga-tmp-a @ ngunnga-tmp-i @ ngunnga-emit-bytes
            1 janay
        kunbayn

        yabarrka
            ngunnga-tmp-a @ c@ 0 junkay yala janay kunbayn
            ngunnga-tmp-a @ 1 muru ngunnga-tmp-a !
        kunbayn
        ngunnga-tmp-a @ 1 muru ngunnga-tmp-a !

        ngunnga-tmp-a @ c@ ngunnga-tmp-i !
        ngunnga-tmp-a @ 1 muru ngunnga-tmp-a !
        ngunnga-tmp-a @ ngunnga-tmp-i @ muru ngunnga-tmp-a !
    kunbayn
kunbayn

balkalaway ngunnga-emit-push-imm

